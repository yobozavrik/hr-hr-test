# Local PostgreSQL from ../docker-compose.yml.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/hr_recruiter?schema=public"
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/hr_recruiter_test?schema=public"

# Supabase Production (connection pooling for app, direct for migrations)
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# SMTP (для отправки email)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# AI API (для анализа резюме и вакансий)
OPENAI_API_KEY=""

# Telegram Bot (для уведомлений)
