<style>
	:root {
		color-scheme: light;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: #f6f8fb;
		color: #14221f;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: #f6f8fb;
	}

	main {
		min-height: 100vh;
		display: grid;
		align-items: center;
		padding: 3rem 1.5rem;
	}

	.hero {
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 1rem;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #4c6f5b;
	}

	h1 {
		margin: 0;
		font-size: 4rem;
		line-height: 0.92;
		letter-spacing: 0;
	}

	.summary {
		margin: 1.5rem 0 0;
		max-width: 580px;
		font-size: 1.125rem;
		line-height: 1.55;
		color: #3e4a42;
	}

	@media (min-width: 720px) {
		main {
			padding: 5rem;
		}

		h1 {
			font-size: 7rem;
		}

		.summary {
			font-size: 1.25rem;
		}
	}

	@media (min-width: 1120px) {
		main {
			padding: 6rem;
		}

		h1 {
			font-size: 9rem;
		}
	}
</style>
